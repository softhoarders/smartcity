# Copy this file to .env for local/server deployment.
# Generate real PARKWATCH_SECRET and VAPID keys before production use.

PARKWATCH_SECRET=replace-with-a-long-random-secret
PARKWATCH_ADMIN_USER=admin
# Bcrypt hash for admin123! by default. Replace for production.
PARKWATCH_ADMIN_HASH=$2b$12$replace-with-real-bcrypt-hash
PARKWATCH_ADMIN_SIGNUP_CODE=admin123!

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@spotflow.com

VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_SUBJECT=mailto:admin@spotflow.com

# Plate document verification (Google Gemini / Google AI Studio)
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash

# Wallet credits (1 Credit = 1 RON lei). Optional display names:
# WALLET_CURRENCY_NAME=Credits
# WALLET_CURRENCY_SINGULAR=Credit
SPOTS_SUBSCRIPTION_LEI=50
SPOTS_SUBSCRIPTION_GRANT=50
SPOTS_INSTANT_HOURLY=10
SPOTS_SCHEDULE_DEPOSIT=5
SPOTS_SCHEDULE_HOURLY=8
SPOTS_WELCOME_BONUS=0

# Smart pricing
PRICING_GEMINI_ENABLED=true
PRICING_MIN_TENTHS=50
PRICING_MAX_TENTHS=300
PRICING_REFRESH_INTERVAL=3600
GEO_CACHE_HOURS=24
NOMINATIM_USER_AGENT=Spotflow/1.0 (local dev)

# --- n8n automation (optional) ---
# Self-hosted instance, e.g. https://n8n.softhoarders.me/webhook
N8N_ENABLED=false
N8N_WEBHOOK_BASE_URL=https://n8n.softhoarders.me/webhook
N8N_WEBHOOK_SECRET=
N8N_API_KEY=
# SPOTFLOW_PUBLIC_URL=http://127.0.0.1:2026

# --- Security (optional) ---
# DEVICE_API_KEY=
# SPOTFLOW_FORCE_HTTPS=false
# RATE_LIMIT_LOGIN_ATTEMPTS=8
# SIMULATED_2FA_SHOW_CODE=true
