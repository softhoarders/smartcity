# Copy this file to .env for local/server deployment.
# Generate real PARKWATCH_SECRET and VAPID keys before production use.

PARKWATCH_SECRET=replace-with-a-long-random-secret
PARKWATCH_ADMIN_USER=admin
PARKWATCH_ADMIN_HASH=$2b$12$replace-with-real-bcrypt-hash
PARKWATCH_ADMIN_SIGNUP_CODE=admin123!

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@spotflow.com

VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_SUBJECT=mailto:admin@spotflow.com

# Plate document verification (Google Gemini / Google AI Studio)
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash

# Public base URL (webhooks, evidence links)
SPOTFLOW_PUBLIC_URL=http://127.0.0.1:2026

# Wallet credits (1 Credit = 1 RON lei)
WALLET_CURRENCY_NAME=Credits
WALLET_CURRENCY_SINGULAR=Credit
SPOTS_SUBSCRIPTION_LEI=50
SPOTS_SUBSCRIPTION_GRANT=50
SPOTS_INSTANT_HOURLY=10
SPOTS_SCHEDULE_DEPOSIT=5
SPOTS_SCHEDULE_HOURLY=8
SPOTS_WELCOME_BONUS=0
LOW_BALANCE_THRESHOLD=1000

# Find parking
FIND_PARKING_RADIUS_KM=12
BUCHAREST_CENTER_LAT=44.4268
BUCHAREST_CENTER_LNG=26.1025

# Smart pricing
PRICING_GEMINI_ENABLED=true
PRICING_MIN_TENTHS=50
PRICING_MAX_TENTHS=300
PRICING_REFRESH_INTERVAL=3600
PRICING_CENTRAL_KM=2.5
PRICING_INNER_KM=8.0
GEO_CACHE_HOURS=24
NOMINATIM_USER_AGENT=Spotflow/1.0 (local dev)

# AI concierge + predictive availability
CONCIERGE_ENABLED=true
CONCIERGE_MODEL=gemini-2.5-flash
WAITLIST_DEFAULT_AUTO_BOOK=true
WAITLIST_MAX_ACTIVE_PER_USER=5
WAITLIST_GRACE_MINUTES=15
AVAILABILITY_HISTORY_DAYS=30

# Flow routing (at destination vs park nearby + walk)
ROUTING_DIRECT_MAX_KM=0.35
ROUTING_WALK_SPEED_KMH=4.8
ROUTING_RECOMMEND_DIRECT=2
ROUTING_RECOMMEND_FLOW=2
ROUTING_RECOMMEND_TOTAL=4
ROUTING_CONCIERGE_DIRECT=2
ROUTING_CONCIERGE_FLOW=1
ROUTING_CONCIERGE_TOTAL=3

# Parking trust passport
REPUTATION_DEFAULT_NEW_SCORE=55
REPUTATION_MIN_AUTO_BOOK=45
REPUTATION_BLOCK_BELOW=25
REPUTATION_TIER_FLAGGED_MAX=30
REPUTATION_TIER_RESTRICTED_MAX=45
REPUTATION_TIER_GOOD_MAX=65
REPUTATION_TIER_TRUSTED_MAX=80
REPUTATION_TIER_EXCELLENT_MAX=90

# n8n automation (optional)
N8N_ENABLED=false
N8N_WEBHOOK_BASE_URL=https://n8n.example.com/webhook
N8N_WEBHOOK_SECRET=
N8N_API_KEY=

# Security / edge (optional)
# DEVICE_API_KEY=
# SPOTFLOW_FORCE_HTTPS=false
# SIMULATED_2FA_SHOW_CODE=true
# MOCK_LOGIN_2FA_PIN=456789
