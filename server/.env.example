# Copy this file to .env for local/server deployment.
# Generate real PARKWATCH_SECRET and VAPID keys before production use.

PARKWATCH_SECRET=replace-with-a-long-random-secret
PARKWATCH_ADMIN_USER=admin
# Bcrypt hash for admin123! by default. Replace for production.
PARKWATCH_ADMIN_HASH=$2b$12$replace-with-real-bcrypt-hash
PARKWATCH_ADMIN_SIGNUP_CODE=admin123!

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@parkscan.com

VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_SUBJECT=mailto:admin@parkscan.com

